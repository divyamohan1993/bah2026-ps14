# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.installed.cfg
pip-wheel-metadata/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Testing / coverage / typing caches ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
coverage.xml

# --- Notebooks ---
.ipynb_checkpoints/

# --- Experiment tracking ---
mlruns/
wandb/
lightning_logs/

# --- Data (do NOT commit downloaded/derived data, but keep the folders) ---
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
# Synthetic data is regenerable via `make synth-data` / scripts/run_demo.py; do not commit
# the (large) generated arrays. Keep the folder placeholder only.
!data/raw/synthetic/
data/raw/synthetic/*
!data/raw/synthetic/.gitkeep
data/manifest.csv

# --- CDF files: ignore all (synthetic CDFs are regenerated by the demo) ---
*.cdf

# --- Models / trained artifacts ---
models/*
!models/.gitkeep
*.pt
*.pth
*.onnx
*.joblib
*.ckpt

# --- Reports (regenerable) ---
reports/*
!reports/.gitkeep

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.swp
